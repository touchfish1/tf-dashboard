# ─── Authentication ──────────────────────────────
# API key required for all /api/* requests.
# Leave empty to disable auth (local dev only).
API_KEY=

# ─── Database ─────────────────────────────────────
DATABASE_URL=postgresql://zhangyuan:zhangyuan@100.125.148.23:5432/tf_dashboard

# ─── DeepSeek API ────────────────────────────────
DEEPSEEK_API_KEY=

# ─── Polling Intervals (seconds) ─────────────────
POLL_SERVERS_INTERVAL=30
POLL_OPENCODE_INTERVAL=60
POLL_DEEPSEEK_INTERVAL=300

# ─── Agent (metrics + OpenCode API proxy) ───────
METRICS_PORT=9100
METRICS_HOST=0.0.0.0
# OPENCODE_API_KEY=set-this-to-protect-the-opencode-endpoint

# ─── Logging ─────────────────────────────────────
# Log level: trace, debug, info, warn, error, fatal (default: info)
LOG_LEVEL=info
# Set to "false" to disable pino-pretty (force raw JSON for production)
PINO_PRETTY=true

# ─── OpenObserve ───────────────────────────────────
# 默认已硬编码内网配置，以下可覆盖：
# OPENOBSERVE_URL=http://100.125.148.23:5080
# OPENOBSERVE_ORG=default
# OPENOBSERVE_STREAM=tf-dashboard
# OPENOBSERVE_AUTH=admin@example.com:Cheng1008611.

# ─── API Server ──────────────────────────────────
API_PORT=3000
API_HOST=0.0.0.0

# ─── OpenCode (API takes priority over local DB) ──
# OPENCODE_API_URL=https://your-server.com/api/opencode/usage
# OPENCODE_API_KEY=your-api-key
OPENCODE_DB_PATH=$HOME/.local/share/opencode/opencode.db
